# ============================================================
#  AgentForge — environment configuration
#  Copy this file to ".env" and fill in values.
#  Everything here has a FREE option. Only GROQ_API_KEY is required.
# ============================================================

# --- REQUIRED: the LLM provider (free tier at https://console.groq.com) ---
# Sign up, create an API key, paste it here. Free tier is generous.
GROQ_API_KEY=

# OPTIONAL: extra keys (comma-separated) to spread traffic / rate limits.
# The app round-robins across the primary key + all of these.
# GROQ_API_KEYS=gsk_second_key,gsk_third_key

# --- Default model used when an agent doesn't specify one ---
# Free Groq models: openai/gpt-oss-20b (most reliable tool calls), llama-3.1-8b-instant
DEFAULT_MODEL=openai/gpt-oss-20b

# --- RECOMMENDED: Connect Gmail with Google sign-in (OAuth, no password) ---
# Create a "Web application" OAuth client at:
#   https://console.cloud.google.com/apis/credentials
# Enable the Gmail API, add the redirect URI below, then paste the id/secret.
# Full step-by-step: docs/CONNECT_GOOGLE.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/api/connections/google/callback

# --- OPTIONAL (fallback): email via Gmail IMAP App Password ---
# Only needed if you prefer NOT to use Google sign-in above.
# https://myaccount.google.com/apppasswords
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=

# --- OPTIONAL: local/private model (nothing leaves your device) ---
# Install Ollama (https://ollama.com), run `ollama pull llama3.2`, then flip the
# provider to "ollama" in the app's settings panel (or set LLM_PROVIDER=ollama).
LLM_PROVIDER=groq
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# --- Paths (defaults are fine) ---
# Sandbox directory the file tools are allowed to touch.
WORKSPACE_DIR=./data/workspace

# --- CORS: where the frontend runs ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Admin console (CHANGE THESE before deploying anywhere public) ---
ADMIN_USERNAME=dj
ADMIN_PASSWORD=dj

# ============================================================
#  CLOUD DEPLOY ONLY (leave blank for local dev) — see docs/DEPLOY_CLOUD.md
# ============================================================
# When DATABASE_URL is set, the app uses Postgres + an ENCRYPTED database secret
# store instead of SQLite + the OS keychain. Render injects DATABASE_URL for you.
DATABASE_URL=
# A stable random secret (e.g. `openssl rand -hex 32`). REQUIRED in the cloud so
# logins + stored tokens survive restarts. Leave blank locally.
SECRET_KEY=
