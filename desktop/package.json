{
  "name": "agentforge-desktop",
  "version": "0.1.1",
  "description": "AgentForge desktop app",
  "main": "main.js",
  "author": "AgentForge",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.agentforge.app",
    "productName": "AgentForge",
    "files": ["main.js", "preload.js", "build/**/*"],
    "protocols": [
      {
        "name": "AgentForge",
        "schemes": ["agentforge"]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Prateek22672",
        "repo": "agent-forge",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AgentForge",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "AgentForge-Setup.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "dmg": {
      "artifactName": "AgentForge.dmg"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Utility"
    }
  }
}
